# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# content (large transcript files)
content/transcripts/*.md
content/transcripts/manifest.json

# vault generation cache
scripts/vault-generation/.cache/

# generated vault (regenerated from DB)
vault/

# git worktrees
.worktrees/
.superpowers/

# playwright mcp scratch
.playwright-mcp/

# playwright test artifacts (videos, traces)
/test-results/
/playwright-report/

# editor / agent local configs
/.claude/
/.obsidian/

# loose screenshots at repo root (scratch — keep curated ones under docs/)
/*.png
content/transcripts-external/
